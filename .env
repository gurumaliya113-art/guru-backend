PORT=4000

# Storage adapter: "json" (default, local file) or "supabase" (later)
STORAGE=json

# Supabase config — fill these when you switch STORAGE=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Admin credentials — used to log into /admin
ADMIN_EMAIL=admin@smartprep.local
ADMIN_PASSWORD=changeme

# Optional: Gemini AI key for smart PDF parsing
# Get a FREE key at https://aistudio.google.com/app/apikey (no credit card needed)
# Supported models: gemini-2.0-flash (recommended), gemini-1.5-pro, gemini-1.5-flash
# Supports UTF-8 Hindi text and other Indian languages
GEMINI_API_KEY=AIzaSyAGn-zK_hcl84VOHa-iUfsCRoNGeP65NlM
GEMINI_MODEL=gemini-2.0-flash
