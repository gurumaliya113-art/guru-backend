# Environment variables for Exam-Prep-Hub Backend

# Server port
PORT=4000

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:5173

# PostgreSQL is no longer required when using Supabase auth + storage.
# If you want to keep using PostgreSQL, uncomment DATABASE_URL below.
# DATABASE_URL=postgresql://username:password@localhost:5432/exam_prep_hub

# Session secret (change this in production!)
SESSION_SECRET=your-super-secret-session-key-change-in-production

# Google OAuth 2.0 credentials
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Storage adapter: "json" (default, local file) or "supabase" (production)
STORAGE=supabase

# Supabase configuration (replace with your actual values from Supabase dashboard)
SUPABASE_URL=https://hsevchffduyxfrcrxakc.supabase.co
