PORT=4000

# Storage adapter: "json" (default, local file) or "supabase" (later)
STORAGE=json

# Supabase config — fill these when you switch STORAGE=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Admin credentials — used to log into /admin
ADMIN_EMAIL=admin@smartprep.local
ADMIN_PASSWORD=changeme

# --- Free Groq AI parser (RECOMMENDED) ---
# Llama 3.3 70B, FREE tier, 30 req/min. Get a key at https://console.groq.com/keys
# Way better than Gemini for our exam-paper extraction. No credit card needed.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Supabase Storage bucket name for original PDF bytes (default: "papers")
SUPABASE_PDF_BUCKET=papers

# Optional: Gemini AI key (legacy, kept as fallback if you want it)
# Get a FREE key at https://aistudio.google.com/app/apikey (no credit card needed)
# Leave GEMINI_API_KEY blank to use only Groq + heuristic parsers.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
