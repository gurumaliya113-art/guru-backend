PORT=4000

# Storage adapter: "json" (default, local file) or "supabase" (later)
STORAGE=json

# Supabase config — fill these when you switch STORAGE=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google OAuth client ID used to verify the Google sign-in credential.
GOOGLE_CLIENT_ID=

# Admin credentials — used to log into /admin
ADMIN_EMAIL=admin@smartprep.local
ADMIN_PASSWORD=changeme

# Invite-only code required to register as a teacher. Share this only with
# trusted teachers; students cannot create teacher accounts without it.
TEACHER_INVITE_CODE=changeme-teacher-code

# --- Free Groq AI parser (RECOMMENDED) ---
# Llama 3.3 70B, FREE tier, 30 req/min. Get a key at https://console.groq.com/keys
# Way better than Gemini for our exam-paper extraction. No credit card needed.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Supabase Storage bucket name for original PDF bytes (default: "papers")
SUPABASE_PDF_BUCKET=papers

# Optional: Gemini AI key for smart parsing / DPP / answers
# Put only one key here.
# Get a FREE key at https://aistudio.google.com/app/apikey (no credit card needed)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Razorpay (paid subscription) ---
# Get keys at https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID is also exposed to the frontend as VITE_RAZORPAY_KEY_ID.
# RAZORPAY_KEY_SECRET is server-side ONLY (never ship to the client).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Subscription plan: amount in paise (₹49 = 4900), currency, validity.
RAZORPAY_PLAN_AMOUNT_PAISE=4900
RAZORPAY_PLAN_CURRENCY=INR
RAZORPAY_PLAN_VALIDITY_DAYS=365
