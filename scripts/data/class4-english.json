    { "type": "mcq", "topic": "Nouns", "text": "Which is an abstract noun?", "options": ["table", "honesty", "dog", "river"], "correctIndex": 1, "explanation": "'Honesty' is a quality we cannot touch, so it is an abstract noun.", "difficulty": "Moderate" },
    { "type": "fill", "topic": "Nouns", "text": "A group of sheep is called a ____.", "options": ["herd", "flock", "pack", "swarm"], "correctIndex": 1, "explanation": "A group of sheep is a flock.", "difficulty": "Moderate" },
    { "type": "truefalse", "topic": "Nouns", "text": "'Childhood' is an abstract noun.", "options": ["True", "False"], "correctIndex": 0, "explanation": "Childhood is a state/idea, so it is abstract. True.", "difficulty": "Moderate" },
    { "type": "mcq", "topic": "Verbs", "text": "Choose the helping verb: 'She is reading.'", "options": ["She", "is", "reading", "a"], "correctIndex": 1, "explanation": "'is' is the helping (auxiliary) verb here.", "difficulty": "Moderate" },
    { "type": "fill", "topic": "Verbs", "text": "Past tense of 'write' is ____.", "options": ["writed", "wrote", "written", "writing"], "correctIndex": 1, "explanation": "The past tense of 'write' is 'wrote'.", "difficulty": "Moderate" },
    { "type": "truefalse", "topic": "Verbs", "text": "In 'They have finished', 'have' is a helping verb.", "options": ["True", "False"], "correctIndex": 0, "explanation": "'have' helps the main verb 'finished'. True.", "difficulty": "Moderate" },
    { "type": "mcq", "topic": "Adjectives", "text": "Choose the comparative form of 'tall'.", "options": ["tall", "taller", "tallest", "more tall"], "correctIndex": 1, "explanation": "'Taller' compares two things, so it is the comparative.", "difficulty": "Moderate" },
    { "type": "fill", "topic": "Adjectives", "text": "Superlative of 'big' is ____.", "options": ["bigger", "biggest", "more big", "big"], "correctIndex": 1, "explanation": "The superlative of big is 'biggest'.", "difficulty": "Moderate" },
    { "type": "truefalse", "topic": "Adjectives", "text": "'More beautiful' is the comparative of 'beautiful'.", "options": ["True", "False"], "correctIndex": 0, "explanation": "Long adjectives use 'more' for comparison. True.", "difficulty": "Moderate" },
    { "type": "mcq", "topic": "Adverbs", "text": "Choose the adverb: 'He ran quickly.'", "options": ["He", "ran", "quickly", "the"], "correctIndex": 2, "explanation": "'Quickly' tells how he ran, so it is an adverb.", "difficulty": "Moderate" },
    { "type": "fill", "topic": "Adverbs", "text": "The adverb formed from 'careful' is ____.", "options": ["careful", "carefully", "carefuly", "carefulness"], "correctIndex": 1, "explanation": "Add -ly: careful → carefully.", "difficulty": "Moderate" },
    { "type": "truefalse", "topic": "Adverbs", "text": "Adverbs often tell us how, when or where an action happens.", "options": ["True", "False"], "correctIndex": 0, "explanation": "Adverbs describe how/when/where. True.", "difficulty": "Moderate" },
    { "type": "mcq", "topic": "Tenses", "text": "Choose the future tense: ", "options": ["I sang.", "I sing.", "I will sing.", "I am singing."], "correctIndex": 2, "explanation": "'I will sing' is future tense.", "difficulty": "Moderate" },
    { "type": "fill", "topic": "Tenses", "text": "She ____ her homework yesterday. (do)", "options": ["does", "did", "do", "will do"], "correctIndex": 1, "explanation": "Past tense of 'do' is 'did'.", "difficulty": "Moderate" },
    { "type": "truefalse", "topic": "Tenses", "text": "'I have eaten' is present perfect tense.", "options": ["True", "False"], "correctIndex": 0, "explanation": "'have eaten' is present perfect. True.", "difficulty": "Moderate" },
    { "type": "mcq", "topic": "Opposites (Antonyms)", "text": "Opposite of 'victory' is ____.", "options": ["win", "defeat", "success", "joy"], "correctIndex": 1, "explanation": "The opposite of victory is defeat.", "difficulty": "Moderate" },
    { "type": "fill", "topic": "Opposites (Antonyms)", "text": "Opposite of 'generous' is ____.", "options": ["kind", "selfish/stingy", "giving", "helpful"], "correctIndex": 1, "explanation": "The opposite of generous is selfish/stingy.", "difficulty": "Moderate" },
    { "type": "truefalse", "topic": "Opposites (Antonyms)", "text": "Opposite of 'arrive' is 'depart'.", "options": ["True", "False"], "correctIndex": 0, "explanation": "Arrive (come) and depart (leave) are opposites. True.", "difficulty": "Moderate" },
    { "type": "mcq", "topic": "Vocabulary", "text": "Choose the synonym of 'happy'.", "options": ["sad", "joyful", "angry", "tired"], "correctIndex": 1, "explanation": "'Joyful' means the same as happy.", "difficulty": "Easy" },
