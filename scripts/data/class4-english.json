    { "type": "truefalse", "topic": "Vocabulary", "text": "'Tiny' and 'huge' are synonyms.", "options": ["True", "False"], "correctIndex": 1, "explanation": "Tiny and huge are opposites, not synonyms. False.", "difficulty": "Moderate" },
