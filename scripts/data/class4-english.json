    { "type": "truefalse", "topic": "Articles and Prepositions", "text": "We use 'an' before words starting with a vowel sound.", "options": ["True", "False"], "correctIndex": 0, "explanation": "'an' is used before vowel sounds. True.", "difficulty": "Easy" },
    { "type": "mcq", "topic": "Sentences", "text": "Which is a compound word?", "options": ["football", "running", "happy", "table"], "correctIndex": 0, "explanation": "'Football' = foot + ball, a compound word.", "difficulty": "Moderate" },
