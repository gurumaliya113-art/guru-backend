    { "type": "truefalse", "topic": "Sentences", "text": "A compound word is made by joining two words.", "options": ["True", "False"], "correctIndex": 0, "explanation": "Compound words join two words (e.g., sun+flower). True.", "difficulty": "Easy" },
    { "type": "mcq", "topic": "Vocabulary", "text": "What is the plural of 'child'?", "options": ["childs", "childes", "children", "childrens"], "correctIndex": 2, "explanation": "The plural of child is children.", "difficulty": "Moderate" },
    { "type": "fill", "topic": "Vocabulary", "text": "The plural of 'mouse' is ____.", "options": ["mouses", "mice", "mouse", "mices"], "correctIndex": 1, "explanation": "The plural of mouse is mice.", "difficulty": "Moderate" },
    { "type": "truefalse", "topic": "Vocabulary", "text": "The plural of 'tooth' is 'teeth'.", "options": ["True", "False"], "correctIndex": 0, "explanation": "Tooth → teeth. True.", "difficulty": "Moderate" },
